{
  "name": "fullstack-phonebook-application",
  "version": "3.0.1",
  "description": "A modern phonebook application with real-time validation, international phone number support, and comprehensive testing. Originally created for Full Stack Open 2023, modernized in 2026.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "NODE_ENV=development node --env-file=.env --watch-path=server --watch-path=index.js index.js",
    "dev:client": "webpack-dev-server --open --mode development",
    "start": "NODE_ENV=production node --env-file=.env index.js",
    "start:test": "NODE_ENV=test node --env-file=.env index.js",
    "build": "webpack --mode production",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "node --require @babel/register --require ./client/test-setup.js --test client/components/*.test.js",
    "test:backend": "NODE_ENV=test node --env-file-if-exists=.env --test --test-concurrency=1 server/tests/*.test.js",
    "test:watch": "NODE_ENV=test node --env-file-if-exists=.env --test --watch --test-concurrency=1 server/tests/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "yumeangelica",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@eslint/js": "^9.39.4",
    "@babel/register": "^7.27.1",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.2.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.20.0",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.3",
    "jsdom": "^26.1.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.1.1",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "libphonenumber-js": "^1.12.9",
    "mongoose": "^9.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
